{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "quantbench-api",
      "runtimeExecutable": ".venv/bin/python3",
      "runtimeArgs": ["-m", "uvicorn", "quantbench.api.server:app", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "quantbench-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev", "--", "--port", "5173"],
      "port": 5173
    }
  ]
}
